# ---- Runtime ----
ENV=dev
PORT=8080
LOG_LEVEL=INFO

# ---- GCP ----
GCP_PROJECT_ID=fluidra-pool-asst-dev
GCP_REGION=europe-west1

# ---- Datastores (credentials never committed; use Secret Manager in cloud) ----
DATABASE_URL=postgresql+asyncpg://postgres:localdev@localhost:5432/assistant
DATABASE_URL_SYNC=postgresql://postgres:localdev@localhost:5432/assistant
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- AI ----
VERTEX_LOCATION=europe-west1
GEMINI_MODEL_FAST=gemini-2.0-flash
GEMINI_MODEL_DEEP=gemini-2.0-pro
EMBEDDING_MODEL=text-embedding-005

# ---- Safety ----
SAFETY_POLICY_VERSION=2025.06.0
KILL_SWITCH_FLAG=assistant_enabled
MAX_TURNS_MEMORY=10

# ---- Secret references (resolved at runtime in cloud via Secret Manager) ----
# DB_PASSWORD_SECRET=projects/.../secrets/db-password/versions/latest
# FIREBASE_CONFIG_SECRET=projects/.../secrets/firebase-config/versions/latest
